# Optional: enable Plausible analytics (privacy-friendly, no cookies).
# Set this in Cloudflare Pages → Settings → Environment variables for production builds.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=quantized.uk

# Search engine ownership verification (HTML meta tag, injected at build time).
# Google Search Console → Settings → Ownership verification → HTML tag method.
# Optional override — default is set in lib/seo.ts
# GOOGLE_SITE_VERIFICATION=your-google-verification-code
# Optional override — default is set in lib/seo.ts
# BING_SITE_VERIFICATION=your-bing-verification-code